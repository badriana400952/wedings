generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

//////////////////////
// ENUM
//////////////////////

enum Role {
  ADMIN
  DEV
}

enum DesignThemes {
  CLASSIC
  MODERN
  ELEGANT
  MINIMALIST
}

//////////////////////
// USER
//////////////////////

model User {
  id                  String   @id @default(uuid())
  email               String   @unique
  name                String
  password            String
  accessKey           String   @unique @map("access_key")
  tz                  String   @default("Asia/Jakarta")
  tenorKey            String?  @map("tenor_key")
  isFilter            Boolean  @default(true) @map("is_filter")
  isConfettiAnimation Boolean  @default(true) @map("is_confetti_animation")
  canReply            Boolean  @default(true) @map("can_reply")
  canEdit             Boolean  @default(true) @map("can_edit")
  canDelete           Boolean  @default(true) @map("can_delete")
  role                Role     @default(ADMIN)
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  templateWeding TemplateWeding?
  template       String          @default("A") @map("template") // "A", "B", "C", dll
  sessions       Session[]

  @@map("users")
}

//////////////////////
// TEMPLATE WEDDING
//////////////////////

model TemplateWeding {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  designTheme DesignThemes @default(CLASSIC)

  fotoHeader  String? @map("foto_header")
  fotoHeader2 String? @map("foto_header2")
  fotoHeader3 String? @map("foto_header3")
  fotoHeader4 String? @map("foto_header4")

  // Groom
  namaPutra        String @default("") @map("nama_putra")
  namaLengkapPutra String @default("") @map("nama_lengkap_putra")
  namaAyahPutra    String @default("") @map("nama_ayah_putra")
  namaIbuPutra     String @default("") @map("nama_ibu_putra")
  instagramPutra   String @default("") @map("instagram_putra")
  photoPutra       String @default("") @map("photo_putra")

  // Bride
  namaPutri        String @default("") @map("nama_putri")
  namaLengkapPutri String @default("") @map("nama_lengkap_putri")
  namaAyahPutri    String @default("") @map("nama_ayah_putri")
  namaIbuPutri     String @default("") @map("nama_ibu_putri")
  instagramPutri   String @default("") @map("instagram_putri")
  photoPutri       String @default("") @map("photo_putri")

  // Wedding Info
  tanggalPernikahan  DateTime @default(now()) @map("tanggal_pernikahan")
  linkGoogleCalender String   @default("") @map("link_google_calendar")
  alamatGedungPernikahan   String   @default("") @map("alamat_gedung_pernikahan")
  alamatPernikahan   String   @default("") @map("alamat_pernikahan")
  jamMulai           String   @default("") @map("jam_mulai")
  jamResepsi           String   @default("") @map("jam_resepsi")
  jamSelesai         String   @default("") @map("jam_selesai")
  linkMaps           String   @default("") @map("link_maps")

  // Love Gift
  noAtm    String? @map("no_atm")
  namaBank String? @map("nama_bank")
  fotoQris String? @map("foto_qris")
  noHp     String? @map("no_hp")

  // Relations
  galeryId String? @map("galery_id")
  galery   Galery? @relation(fields: [galeryId], references: [id], onDelete: SetNull)

  pertemuanId String?
  pertemuan   Pertemuan?
  comentIds   String?
  comments    Comment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("template_wedings")
}

//////////////////////
// PERTEMUAN STORY
//////////////////////

model Pertemuan {
  id               String         @id @default(uuid())
  templateWedingId String         @unique @map("template_weding_id")
  templateWeding   TemplateWeding @relation(fields: [templateWedingId], references: [id], onDelete: Cascade)

  judulPertemuanSatu  String @map("judul_pertamaa")
  judulPertemuanDua   String @map("judul_dua")
  judulPertemuanTiga  String @map("judul_tiga")
  judulPertemuanEmpat String @map("judul_empat")
  pertemuanPertama    String @map("pertemuan_pertama")
  pertemuanKedua      String @map("pertemuan_kedua")
  pertemuanKetiga     String @map("pertemuan_ketiga")
  pertemuanKeempat    String @map("pertemuan_keempat")

  @@map("pertemuan")
}

//////////////////////
// GALERY
//////////////////////

model Galery {
  id              String           @id @default(uuid())
  fotos           String[]
  templateWedings TemplateWeding[]

  @@map("galeries")
}

//////////////////////
// COMMENT
//////////////////////

model Comment {
  id               String  @id @default(uuid())
  name             String
  presence         Boolean
  comment          String  @db.Text
  gif              String?
  ip               String
  userAgent        String  @map("user_agent")
  likesCount       Int     @default(0) @map("likes_count")
  parentId         String? @map("parent_id")
  templateWedingId String? @map("template_weding_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  templateWeding TemplateWeding? @relation(fields: [templateWedingId], references: [id], onDelete: Cascade)

  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  likedBy Like[]

  @@index([parentId])
  @@map("comments")
}

//////////////////////
// LIKE
//////////////////////

model Like {
  id        String   @id @default(uuid())
  commentId String   @map("comment_id")
  sessionId String   @map("session_id")
  createdAt DateTime @default(now()) @map("created_at")

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, sessionId])
  @@index([commentId])
  @@map("likes")
}

//////////////////////
// SESSION (AUTH ONLY)
//////////////////////

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}
