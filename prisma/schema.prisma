generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

//////////////////////
// ENUM
//////////////////////

enum Role {
  ADMIN
  DEV
}

enum DesignThemes {
  CLASSIC
  MODERN
  ELEGANT
  MINIMALIST
}

//////////////////////
// USER
//////////////////////

model User {
  id                  String   @id @default(uuid())
  email               String   @unique
  name                String
  password            String
  accessKey           String   @unique @map("access_key")
  tz                  String   @default("Asia/Jakarta")
  tenorKey            String?  @map("tenor_key")
  isFilter            Boolean  @default(true) @map("is_filter")
  isConfettiAnimation Boolean  @default(true) @map("is_confetti_animation")
  canReply            Boolean  @default(true) @map("can_reply")
  canEdit             Boolean  @default(true) @map("can_edit")
  canDelete           Boolean  @default(true) @map("can_delete")
  role                Role     @default(ADMIN)
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  templateWeding      TemplateWeding?
  template            String   @map("template") @default("A")  // "A", "B", "C", dll
  sessions            Session[]
  

  @@map("users")
}

//////////////////////
// TEMPLATE WEDDING
//////////////////////

model TemplateWeding {
  id                String       @id @default(cuid())
  userId            String       @unique @map("user_id")
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  designTheme       DesignThemes @default(CLASSIC)

  fotoHeader        String       @map("foto_header") @default("")

  // Groom
  namaPutra         String       @map("nama_putra") @default("")
  namaLengkapPutra  String       @map("nama_lengkap_putra") @default("")
  namaAyahPutra     String       @map("nama_ayah_putra") @default("")
  namaIbuPutra      String       @map("nama_ibu_putra") @default("")
  instagramPutra    String       @map("instagram_putra") @default("")
  photoPutra        String       @map("photo_putra") @default("")

  // Bride
  namaPutri         String       @map("nama_putri") @default("")
  namaLengkapPutri  String       @map("nama_lengkap_putri") @default("")
  namaAyahPutri     String       @map("nama_ayah_putri") @default("")
  namaIbuPutri      String       @map("nama_ibu_putri") @default("")
  instagramPutri    String       @map("instagram_putri") @default("")
  photoPutri        String       @map("photo_putri") @default("")

  // Wedding Info
  tanggalPernikahan DateTime     @map("tanggal_pernikahan") @default(now())
  linkGoogleCalender String      @map("link_google_calendar") @default("")
  alamatPernikahan  String       @map("alamat_pernikahan") @default("")
  jamMulai          String       @map("jam_mulai") @default("")
  jamSelesai        String       @map("jam_selesai") @default("")
  linkMaps          String       @map("link_maps") @default("")

  // Love Gift
  noAtm             String?      @map("no_atm")
  namaBank          String?      @map("nama_bank")
  fotoQris          String?      @map("foto_qris")
  noHp              String?      @map("no_hp")

  // Relations
  galeryId          String?      @map("galery_id")
  galery            Galery?      @relation(fields: [galeryId], references: [id], onDelete: SetNull)

  pertemuanId String?
  pertemuan         Pertemuan?
  comentIds String?
  comments          Comment[]

  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  @@map("template_wedings")
}

//////////////////////
// PERTEMUAN STORY
//////////////////////

model Pertemuan {
  id                String         @id @default(uuid())
  templateWedingId  String         @unique @map("template_weding_id")
  templateWeding    TemplateWeding @relation(fields: [templateWedingId], references: [id], onDelete: Cascade)

  judulPertemuanSatu String @map("judul_pertamaa")
  judulPertemuanDua String @map("judul_dua")
  judulPertemuanTiga String @map("judul_tiga")
  judulPertemuanEmpat String @map("judul_empat")
  pertemuanPertama  String         @map("pertemuan_pertama")
  pertemuanKedua    String         @map("pertemuan_kedua")
  pertemuanKetiga   String         @map("pertemuan_ketiga")
  pertemuanKeempat  String         @map("pertemuan_keempat")

  @@map("pertemuan")
}

//////////////////////
// GALERY
//////////////////////

model Galery {
  id              String           @id @default(uuid())
  fotos           String[]
  templateWedings TemplateWeding[]

  @@map("galeries")
}

//////////////////////
// COMMENT
//////////////////////

model Comment {
  id               String   @id @default(uuid())
  name             String
  presence         Boolean
  comment          String   @db.Text
  gif              String?
  ip               String
  userAgent        String   @map("user_agent")
  likesCount       Int      @default(0) @map("likes_count")
  parentId         String?  @map("parent_id")
  templateWedingId String?  @map("template_weding_id")

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  templateWeding   TemplateWeding? @relation(fields: [templateWedingId], references: [id], onDelete: Cascade)

  parent           Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies          Comment[] @relation("CommentReplies")

  likedBy          Like[]

  @@index([parentId])
  @@map("comments")
}

//////////////////////
// LIKE
//////////////////////

model Like {
  id        String   @id @default(uuid())
  commentId String   @map("comment_id")
  sessionId String   @map("session_id")
  createdAt DateTime @default(now()) @map("created_at")

  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, sessionId])
  @@index([commentId])

  @@map("likes")
}

//////////////////////
// SESSION (AUTH ONLY)
//////////////////////

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])

  @@map("sessions")
}