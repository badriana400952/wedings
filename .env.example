# Database Configuration
# Local Development (PostgreSQL local atau Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/undangan_dev"
POSTGRES_URL="postgresql://postgres:postgres@localhost:5432/undangan_dev"

# Production (PostgreSQL - Prisma Cloud atau Vercel)
# DATABASE_URL="postgres://user:password@host:5432/database?sslmode=require"
# POSTGRES_URL="postgres://user:password@host:5432/database?sslmode=require"

# Prisma Accelerate (optional)
# PRISMA_DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_API_KEY"

# NextAuth Configuration
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-change-this-in-production"

# Development
NEXTAUTH_URL="http://localhost:3000"

# Production (ganti dengan domain Anda)
# NEXTAUTH_URL="https://your-domain.vercel.app"

# Admin Default Credentials (untuk seed database)
# Email: admin@undangan.com
# Password: admin123
# ⚠️ Ganti password setelah login pertama!
