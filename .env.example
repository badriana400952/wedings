# Database Configuration
# Local Development (Database development terpisah)
DATABASE_URL="postgres://user:password@db.prisma.io:5432/postgres?sslmode=require"
POSTGRES_URL="postgres://user:password@db.prisma.io:5432/postgres?sslmode=require"
PRISMA_DATABASE_URL="postgres://user:password@db.prisma.io:5432/postgres?sslmode=require"

# Production (Database production)
# DATABASE_URL="postgres://user:password@db.prisma.io:5432/postgres?sslmode=require"
# POSTGRES_URL="postgres://user:password@db.prisma.io:5432/postgres?sslmode=require"
# PRISMA_DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_API_KEY"

# NextAuth Configuration
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-change-this-in-production"

# Development
NEXTAUTH_URL="http://localhost:3000"

# Production (ganti dengan domain Anda)
# NEXTAUTH_URL="https://your-domain.vercel.app"

